# GenAI (server-side only)
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional — defaults to gemini-2.5-flash (gemini-2.0-flash was shut down June 2026)
GEMINI_MODEL=gemini-3.5-flash

# ElevenLabs TTS (server-side only)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Supabase (URL + anon key are public-safe with RLS; service role is server-only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
